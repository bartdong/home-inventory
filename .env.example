# 家庭收纳后端 — 环境变量
# 复制为 .env 后填入实际值

# 数据库路径
DATABASE_PATH=/var/lib/home-inventory/data.db

# 管理 API 密钥（用于生成 Magic Link）
ADMIN_KEY=

# Session 密钥（随机字符串）
SESSION_SECRET=

# Session 滑动窗口（分钟，有操作续期）
SESSION_LIFETIME_MINUTES=30

# Magic Link 有效期（分钟）
MAGIC_LINK_EXPIRE_MINUTES=5

# 后端端口
BACKEND_PORT=3002

# 部署域名
DOMAIN=hk0.bartdong.fun
